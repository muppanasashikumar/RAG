RAG_LLM_PROVIDER=openai_compatible
RAG_LLM_BASE_URL=https://api.groq.com/openai
RAG_LLM_MODEL=openai/gpt-oss-20b
RAG_LLM_API_KEY=replace-with-your-api-key
RAG_LLM_REASONING_EFFORT=medium
RAG_LLM_TIMEOUT_SECONDS=120
RAG_MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/
RAG_MONGODB_DATABASE=rag_app
RAG_MONGODB_USE_VECTOR_SEARCH=true
RAG_MONGODB_VECTOR_INDEX_NAME=rag_chunks_vector_index
RAG_MONGODB_VECTOR_NUM_CANDIDATES=100
RAG_CELERY_BROKER_URL=redis://localhost:6379/0
RAG_CELERY_RESULT_BACKEND=redis://localhost:6379/1