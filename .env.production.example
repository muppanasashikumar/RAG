# Public URL for browser calls to backend (use your domain)
NEXT_PUBLIC_BACKEND_API_URL=https://api.example.com

# Backend service settings
OPENAI_API_KEY=your_openai_or_groq_key
OPENAI_BASE_URL=https://api.groq.com/openai/v1
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=rag_db
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_STORAGE_BUCKET=documents
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_OBJECT_PREFIX=documents
DOCUMENT_STORAGE_PROVIDER=supabase

# Optional backend overrides
VECTOR_COLLECTION=vector_documents
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_ENABLED=false
RERANKER_MODEL=BAAI/bge-reranker-base
LLM_MODEL=openai/gpt-oss-20b
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Optional auth
# API_AUTH_TOKEN=your_api_token
# CLERK_JWKS_URL=https://your-clerk-domain/.well-known/jwks.json
# CLERK_ISSUER=https://your-clerk-domain
# CLERK_AUDIENCE=your-clerk-audience
