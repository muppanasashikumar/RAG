OPENAI_API_KEY=your_groq_api_key
OPENAI_BASE_URL=https://api.groq.com/openai/v1
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=rag_db
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_STORAGE_BUCKET=documents
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_OBJECT_PREFIX=documents
DOCUMENT_STORAGE_PROVIDER=supabase

# Optional overrides
VECTOR_COLLECTION=vector_documents
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_CACHE_SIZE=2000
RERANKER_ENABLED=false
RERANKER_MODEL=BAAI/bge-reranker-base
DOCUMENT_EXTRACTION_MAX_WORKERS=1
INGEST_ENABLE_HI_RES_OCR=false
LLM_MODEL=openai/gpt-oss-20b
RAG_RETRIEVAL_TIMEOUT_SECONDS=25
RAG_NEXT_TOKEN_TIMEOUT_SECONDS=60
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
REDIS_URL=redis://localhost:6379/0
RQ_INGEST_QUEUE_NAME=ingestion
RQ_INGEST_MAX_RETRIES=3
RQ_INGEST_RETRY_INTERVALS=10,30,90
